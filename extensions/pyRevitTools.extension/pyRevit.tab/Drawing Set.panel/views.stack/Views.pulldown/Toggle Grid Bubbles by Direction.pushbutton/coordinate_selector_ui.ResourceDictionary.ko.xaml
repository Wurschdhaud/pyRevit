<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="Title">그리드 버블 설정</system:String>
    <system:String x:Key="HeaderTitle">그리드 버블 설정</system:String>
    <system:String x:Key="Subtitle">좌표계 및 각도 허용 오차 구성</system:String>

    <system:String x:Key="CoordinateSystemHeader">좌표계</system:String>
    <system:String x:Key="AllGrids">모든 그리드</system:String>
    <system:String x:Key="AllGridsDescription">활성 뷰의 모든 그리드를 전환합니다</system:String>
    <system:String x:Key="TrueNorth">실제 북쪽</system:String>
    <system:String x:Key="TrueNorthDescription">실제 북쪽 방향을 사용합니다</system:String>
    <system:String x:Key="ProjectNorth">프로젝트 북쪽</system:String>
    <system:String x:Key="ProjectNorthDescription">프로젝트 좌표계를 사용합니다 ('실제 북쪽과의 각도' 적용)</system:String>
    <system:String x:Key="ViewOrientation">뷰/범위 상자 방향</system:String>
    <system:String x:Key="ViewOrientationDescription">현재 뷰 방향 및 범위 상자를 사용합니다</system:String>

    <system:String x:Key="AngleToleranceHeader">각도 허용 오차</system:String>
    <system:String x:Key="StrictLabel">1° (엄격)</system:String>
    <system:String x:Key="PermissiveLabel">40° (허용)</system:String>
    <system:String x:Key="HowThisWorks">작동 방식</system:String>
    <system:String x:Key="HowThisWorksDescription">그리드가 선택한 좌표계에 얼마나 가깝게 정렬되어야 하는지를 제어합니다. 낮은 값 = 직선 그리드만. 높은 값 = 각진 그리드 포함.</system:String>

    <system:String x:Key="AngleDescription1">매우 엄격 - 완벽하게 정렬된 그리드만</system:String>
    <system:String x:Key="AngleDescription5">타이트 - 정밀한 그리드 레이아웃에 적합</system:String>
    <system:String x:Key="AngleDescription10">보통 - 대부분의 경우에 적합</system:String>
    <system:String x:Key="AngleDescription15">완화 - 약간 각진 그리드 포함</system:String>
    <system:String x:Key="AngleDescription25">허용 - 더 많은 각진 그리드 포함</system:String>
    <system:String x:Key="AngleDescription35">매우 허용 - 대부분의 방향 포함</system:String>
    <system:String x:Key="AngleDescription40">최대 허용 - 심하게 각진 그리드 포함</system:String>

    <system:String x:Key="Cancel">취소</system:String>
    <system:String x:Key="Continue">계속</system:String>
</ResourceDictionary>
