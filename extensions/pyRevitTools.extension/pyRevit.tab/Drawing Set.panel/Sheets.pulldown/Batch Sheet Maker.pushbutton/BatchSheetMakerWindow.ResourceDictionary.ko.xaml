<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="Title">일괄 시트 생성기</system:String>

    <system:String x:Key="InstructionsLine1">다음 형식으로 시트 번호와 이름 목록을 입력하세요:</system:String>
    <system:String x:Key="SheetNumberLabel">시트 번호</system:String>
    <system:String x:Key="TAB">TAB</system:String>
    <system:String x:Key="SheetNameLabel">시트 이름</system:String>
    <system:String x:Key="SheetNameExample">시트 이름</system:String>
    <system:String x:Key="InstructionsLine2">동일한 이름의 여러 시트는 시트 번호 범위로 나열할 수 있습니다:</system:String>
    <system:String x:Key="RangeOfSheetNumbers">시트 번호 범위:</system:String>
    <system:String x:Key="RangeExample">예: A103--A106 또는 A103::A106</system:String>
    <system:String x:Key="ListOfSheetNumbers">시트 번호 목록:</system:String>
    <system:String x:Key="ListExample">예: A104,A105 또는 A104;A105</system:String>

    <system:String x:Key="CreateSheets">시트 생성</system:String>
    <system:String x:Key="CreatePlaceholders">자리 표시자 생성</system:String>
    <system:String x:Key="CreateButton">생성</system:String>
</ResourceDictionary>
