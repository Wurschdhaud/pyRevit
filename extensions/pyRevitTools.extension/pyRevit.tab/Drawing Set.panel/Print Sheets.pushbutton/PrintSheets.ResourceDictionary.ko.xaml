<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="Title">시트 인쇄</system:String>

    <system:String x:Key="Model">모델</system:String>
    <system:String x:Key="LinkedPrefix">링크: </system:String>
    <system:String x:Key="SheetIndex">시트 인덱스</system:String>

    <system:String x:Key="SheetOrdering">시트 순서</system:String>
    <system:String x:Key="ReversePrintOrder">인쇄 순서 반전</system:String>
    <system:String x:Key="ShowNonPrintableSheets">인쇄 불가 시트 표시 (회색으로 표시)</system:String>
    <system:String x:Key="IncludeNonPrintableInIndexing">인덱싱에 인쇄 불가 시트 포함</system:String>
    <system:String x:Key="IndexDigits">인덱스 자릿수</system:String>
    <system:String x:Key="IndexStart">인덱스 시작</system:String>
    <system:String x:Key="Reset">초기화</system:String>

    <system:String x:Key="SheetPrinting">시트 인쇄</system:String>
    <system:String x:Key="CombineIntoOnePDF">하나의 PDF로 결합</system:String>
    <system:String x:Key="ExportDWG">DWG 내보내기</system:String>
    <system:String x:Key="NamingFormat">명명 형식</system:String>
