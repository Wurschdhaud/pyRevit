<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Window.Title}"
        Width="400" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <CheckBox x:Name="enable_cb"
                  Grid.Row="0"
                  Content="{DynamicResource ChkEnableStartup}"
                  FontSize="11"
                  Margin="0,0,0,2"/>

        <TextBlock Grid.Row="1"
                   Text="{DynamicResource TbRestartHint}"
                   TextWrapping="Wrap"
                   FontSize="10"
                   Foreground="#888888"
                   Margin="20,0,0,10"/>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource TbParamsHint}"
                   TextWrapping="Wrap"
                   FontSize="11"
                   Foreground="#444444"
                   Margin="0,0,0,8"/>

        <TextBox x:Name="params_tb"
                 Grid.Row="3"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="11"
                 Padding="6"
                 BorderBrush="#AAAAAA"/>

        <TextBlock Grid.Row="4"
                   Text="{DynamicResource TbExamples}"
                   FontSize="10"
                   Foreground="#888888"
                   Margin="0,4,0,8"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource BtnCancel}"
                    Width="72" Height="26" Margin="0,0,8,0"
                    Click="cancel_clicked"/>
            <Button Content="{DynamicResource BtnSave}"
                    Width="72" Height="26"
                    IsDefault="True"
                    Click="save_clicked"/>
        </StackPanel>
    </Grid>
</Window>
