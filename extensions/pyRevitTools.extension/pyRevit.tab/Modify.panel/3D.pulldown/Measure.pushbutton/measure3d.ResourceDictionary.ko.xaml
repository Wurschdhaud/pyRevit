<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="Title">3D 측정 도구</system:String>

    <system:String x:Key="CurrentMeasurement">현재 측정값</system:String>
    <system:String x:Key="Point1NotSelected">점 1: 선택되지 않음</system:String>
    <system:String x:Key="Point2NotSelected">점 2: 선택되지 않음</system:String>
    <system:String x:Key="MeasurementHistory">측정 기록</system:String>
    <system:String x:Key="NoMeasurementsYet">측정값이 없습니다</system:String>
    <system:String x:Key="PressESCToExit">ESC를 눌러 종료</system:String>

    <system:String x:Key="Point1Format">점 1: {}</system:String>
    <system:String x:Key="Point2Format">점 2: {}</system:String>
    <system:String x:Key="DeltaXFormat">ΔX: {:>15}</system:String>
    <system:String x:Key="DeltaYFormat">ΔY: {:>15}</system:String>
    <system:String x:Key="DeltaZFormat">ΔZ: {:>15}</system:String>
    <system:String x:Key="DiagonalFormat">대각선: {}</system:String>
    <system:String x:Key="SlopeFormat">경사: {}</system:String>

    <system:String x:Key="MeasurementHistoryEntry" xml:space="preserve">
측정값 {}:
    P1: {}
    P2: {}
    ΔX: {:>15}
    ΔY: {:>15}
    ΔZ: {:>15}
    대각선: {}
    경사: {}
    </system:String>

    <system:String x:Key="WarningBarPickFirstPoint">첫 번째 점을 선택하세요</system:String>
    <system:String x:Key="WarningBarPickSecondPoint">두 번째 점을 선택하세요</system:String>
    <system:String x:Key="AlertMeasurementCancelled">잘못된 작업으로 인해 측정이 취소되었습니다. 다시 시도하세요.</system:String>
    <system:String x:Key="AlertMeasurementErrorTitle">측정 오류</system:String>
    <system:String x:Key="AlertUnexpectedError">측정 중 예기치 않은 오류가 발생했습니다. 로그를 확인하세요.</system:String>
    <system:String x:Key="ToastMeasurementsCopied">측정값이 클립보드에 복사되었습니다!</system:String>
    <system:String x:Key="ToastMeasure3DTitle">3D 측정</system:String>
    <system:String x:Key="ProjectUnitLengthUnits" xml:space="preserve">
길이 단위 (프로젝트 단위에서 조정):
    </system:String>
    <system:String x:Key="ProjectUnitSlopeUnits" xml:space="preserve">
경사 단위 (프로젝트 단위에서 조정):
    </system:String>
</ResourceDictionary>
