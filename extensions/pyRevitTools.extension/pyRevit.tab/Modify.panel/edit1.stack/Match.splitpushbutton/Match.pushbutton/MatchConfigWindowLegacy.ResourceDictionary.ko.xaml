<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="Title">일치할 옵션 선택:</system:String>

    <system:String x:Key="ElementGraphicsOverrides">요소 그래픽 재정의:</system:String>
    <system:String x:Key="Halftone">하프톤</system:String>
    <system:String x:Key="Transparency">투명도</system:String>

    <system:String x:Key="ProjectionOptions">투영 옵션:</system:String>
    <system:String x:Key="ProjectionLineColor">투영 선 색상</system:String>
    <system:String x:Key="ProjectionLinePattern">투영 선 패턴</system:String>
    <system:String x:Key="ProjectionLineWeight">투영 선 두께</system:String>
    <system:String x:Key="ProjectionFillColor">투영 채우기 색상</system:String>
    <system:String x:Key="ProjectionFillPattern">투영 채우기 패턴</system:String>
    <system:String x:Key="ProjectionFillPatternVisibility">투영 채우기 패턴 가시성</system:String>

    <system:String x:Key="CutOptions">절단 옵션:</system:String>
    <system:String x:Key="CutLineColor">절단 선 색상</system:String>
    <system:String x:Key="CutLinePattern">절단 선 패턴</system:String>
    <system:String x:Key="CutLineWeight">절단 선 두께</system:String>
    <system:String x:Key="CutFillColor">절단 채우기 색상</system:String>
    <system:String x:Key="CutFillPattern">절단 채우기 패턴</system:String>
    <system:String x:Key="CutFillPatternVisibility">절단 채우기 패턴 가시성</system:String>

    <system:String x:Key="DimensionOverrides">치수 재정의:</system:String>
    <system:String x:Key="ReplacedValue">대체 값</system:String>
    <system:String x:Key="TextPosition">텍스트 위치</system:String>
    <system:String x:Key="AboveValue">위 값</system:String>
    <system:String x:Key="BelowValue">아래 값</system:String>
    <system:String x:Key="PrefixValue">접두사 값</system:String>
    <system:String x:Key="PostfixValue">접미사 값</system:String>

    <system:String x:Key="CheckAll">모두 선택</system:String>
    <system:String x:Key="CheckNone">모두 해제</system:String>
    <system:String x:Key="SaveOptions">옵션 저장</system:String>
</ResourceDictionary>
