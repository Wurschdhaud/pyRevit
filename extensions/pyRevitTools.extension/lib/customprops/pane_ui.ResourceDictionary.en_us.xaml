<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Fixed parameter rows -->
    <system:String x:Key="LblWorkset">Workset</system:String>
    <system:String x:Key="ChkWorkset.Tooltip">Include Workset in copy</system:String>
    <system:String x:Key="ComboWorkset.Tooltip">User workset for this element.</system:String>
    <system:String x:Key="LblDesignOption">Design Option</system:String>
    <system:String x:Key="ChkDesignOption.Tooltip">Design Option is read-only</system:String>
    <system:String x:Key="TbDesignOption.Tooltip">Read-only. Design option membership cannot be changed via the API.</system:String>

    <!-- Parameters section -->
    <system:String x:Key="LblParameters">Parameters</system:String>

    <!-- Action buttons -->
    <system:String x:Key="BtnCopy">Copy</system:String>
    <system:String x:Key="BtnCopy.Tooltip">Copy checked parameters from current selection</system:String>
    <system:String x:Key="BtnPaste">Paste</system:String>
    <system:String x:Key="BtnPaste.Tooltip">Fill fields from clipboard — hit Apply to commit</system:String>
    <system:String x:Key="BtnFilter">Filter</system:String>
    <system:String x:Key="BtnFilter.Tooltip">Create/apply an equals view filter for checked parameters</system:String>
    <system:String x:Key="BtnApply">Apply</system:String>

    <!-- Design option fallback -->
    <system:String x:Key="MainModel">Main Model</system:String>

    <!-- Status messages -->
    <system:String x:Key="Varies">Varies</system:String>
    <system:String x:Key="StatusNoSelection">No selection</system:String>
    <system:String x:Key="StatusOneElement">1 element</system:String>
    <system:String x:Key="StatusElements">{} elements</system:String>
    <system:String x:Key="StatusCopied">Copied {} param(s)</system:String>

    <!-- Parameter tooltips -->
    <system:String x:Key="TooltipParamNotFound">Parameter not found on selected elements</system:String>
    <system:String x:Key="TooltipParamMissing">Parameter not available for all selected elements</system:String>
    <system:String x:Key="TooltipParamReadOnly">Parameter not writable for all selected elements</system:String>
    <system:String x:Key="TooltipParamOpaque">Integer option parameter — display only</system:String>
    <system:String x:Key="TooltipMixedValues">Mixed values across selection</system:String>
    <system:String x:Key="TooltipUndo">Reset to current element value</system:String>

</ResourceDictionary>
