<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Linhas de parâmetros fixos -->
    <system:String x:Key="LblWorkset">Workset</system:String>
    <system:String x:Key="ChkWorkset.Tooltip">Incluir workset na cópia</system:String>
    <system:String x:Key="ComboWorkset.Tooltip">Workset de usuário para este elemento.</system:String>
    <system:String x:Key="LblDesignOption">Opção de Projeto</system:String>
    <system:String x:Key="ChkDesignOption.Tooltip">Opção de Projeto é somente leitura</system:String>
    <system:String x:Key="TbDesignOption.Tooltip">Somente leitura. A associação a opções de projeto não pode ser alterada via API.</system:String>

    <!-- Seção de parâmetros -->
    <system:String x:Key="LblParameters">Parâmetros</system:String>

    <!-- Botões de ação -->
    <system:String x:Key="BtnCopy">Copiar</system:String>
    <system:String x:Key="BtnCopy.Tooltip">Copiar parâmetros marcados da seleção atual</system:String>
    <system:String x:Key="BtnPaste">Colar</system:String>
    <system:String x:Key="BtnPaste.Tooltip">Preencher campos da área de transferência — pressione Aplicar para confirmar</system:String>
    <system:String x:Key="BtnFilter">Filtro</system:String>
    <system:String x:Key="BtnFilter.Tooltip">Criar/aplicar um filtro de igualdade de vista para os parâmetros marcados</system:String>
    <system:String x:Key="BtnApply">Aplicar</system:String>

    <!-- Opção de projeto — valor padrão -->
    <system:String x:Key="MainModel">Modelo principal</system:String>

    <!-- Mensagens de status -->
    <system:String x:Key="Varies">Varia</system:String>
    <system:String x:Key="StatusNoSelection">Sem seleção</system:String>
    <system:String x:Key="StatusOneElement">1 elemento</system:String>
    <system:String x:Key="StatusElements">{} elementos</system:String>
    <system:String x:Key="StatusCopied">{} parâmetro(s) copiado(s)</system:String>

    <!-- Dicas de parâmetros -->
    <system:String x:Key="TooltipParamNotFound">Parâmetro não encontrado nos elementos selecionados</system:String>
    <system:String x:Key="TooltipParamMissing">Parâmetro não disponível para todos os elementos selecionados</system:String>
    <system:String x:Key="TooltipParamReadOnly">Parâmetro não editável para todos os elementos selecionados</system:String>
    <system:String x:Key="TooltipParamOpaque">Parâmetro de opção inteira — somente exibição</system:String>
    <system:String x:Key="TooltipMixedValues">Valores mistos na seleção</system:String>
    <system:String x:Key="TooltipUndo">Redefinir para o valor do elemento atual</system:String>

</ResourceDictionary>
