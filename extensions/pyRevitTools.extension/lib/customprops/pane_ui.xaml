<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">

    <Page.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ReadOnlyLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555555"/>
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,6,0,4"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,6,4,0"/>
        </Style>
        <Style x:Key="Separator" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#DDDDDD"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
    </Page.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Status -->
        <TextBlock x:Name="status_tb"
                   Grid.Row="0"
                   Text="No selection"
                   FontStyle="Italic"
                   FontSize="11"
                   Foreground="#666666"
                   Margin="0,0,0,4"/>

        <Border Grid.Row="1" Style="{StaticResource Separator}"/>

        <!-- Row 2: Fixed params (Workset + Design Option) with selection checkboxes -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <CheckBox x:Name="workset_cb"
                      Grid.Row="0" Grid.Column="0"
                      VerticalAlignment="Center"
                      ToolTip="{DynamicResource ChkWorkset.Tooltip}"/>

            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{DynamicResource LblWorkset}"
                       Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="workset_combo"
                      Grid.Row="0" Grid.Column="2"
                      Style="{StaticResource FieldCombo}"
                      ToolTip="{DynamicResource ComboWorkset.Tooltip}"/>

            <Button x:Name="workset_undo_btn"
                    Grid.Row="0" Grid.Column="3"
                    Content="&#x21BA;"
                    Width="18" Height="18"
                    FontSize="12"
                    Padding="0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    ToolTip="{DynamicResource TooltipUndo}"/>

            <CheckBox x:Name="design_option_cb"
                      Grid.Row="1" Grid.Column="0"
                      VerticalAlignment="Center"
                      IsEnabled="False"
                      ToolTip="{DynamicResource ChkDesignOption.Tooltip}"/>

            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{DynamicResource LblDesignOption}"
                       Style="{StaticResource LabelStyle}"/>
            <TextBlock x:Name="design_option_tb"
                       Grid.Row="1" Grid.Column="2"
                       Style="{StaticResource ReadOnlyLabel}"
                       ToolTip="{DynamicResource TbDesignOption.Tooltip}"/>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource Separator}"/>

        <!-- Row 4: Parameters header -->
        <TextBlock Grid.Row="4"
                   Text="{DynamicResource LblParameters}"
                   Style="{StaticResource SectionHeader}"/>

        <!-- Row 5: Parameters (scrollable) -->
        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="additional_panel" Margin="0,0,0,4"/>
        </ScrollViewer>

        <!-- Row 6: Action buttons -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="copy_btn"
                    Grid.Column="0"
                    Content="{DynamicResource BtnCopy}"
                    Click="copy_clicked"
                    IsEnabled="False"
                    Style="{StaticResource ActionButton}"
                    ToolTip="{DynamicResource BtnCopy.Tooltip}"/>

            <Button x:Name="paste_btn"
                    Grid.Column="1"
                    Content="{DynamicResource BtnPaste}"
                    Click="paste_clicked"
                    IsEnabled="False"
                    Style="{StaticResource ActionButton}"
                    ToolTip="{DynamicResource BtnPaste.Tooltip}"/>

            <Button x:Name="filter_btn"
                    Grid.Column="2"
                    Content="{DynamicResource BtnFilter}"
                    Click="filter_clicked"
                    IsEnabled="False"
                    Style="{StaticResource ActionButton}"
                    ToolTip="{DynamicResource BtnFilter.Tooltip}"/>

            <Button Grid.Column="4"
                    Content="{DynamicResource BtnApply}"
                    Padding="16,4"
                    FontSize="11"
                    Margin="0,6,0,0"
                    HorizontalAlignment="Right"
                    Click="apply_clicked"/>
        </Grid>
    </Grid>
</Page>
