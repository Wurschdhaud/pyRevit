<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Lignes de paramètres fixes -->
    <system:String x:Key="LblWorkset">Workset</system:String>
    <system:String x:Key="ChkWorkset.Tooltip">Inclure le workset dans la copie</system:String>
    <system:String x:Key="ComboWorkset.Tooltip">Workset utilisateur de cet élément.</system:String>
    <system:String x:Key="LblDesignOption">Option de conception</system:String>
    <system:String x:Key="ChkDesignOption.Tooltip">L'option de conception est en lecture seule</system:String>
    <system:String x:Key="TbDesignOption.Tooltip">Lecture seule. L'appartenance aux options de conception ne peut pas être modifiée via l'API.</system:String>

    <!-- Section paramètres -->
    <system:String x:Key="LblParameters">Paramètres</system:String>

    <!-- Boutons d'action -->
    <system:String x:Key="BtnCopy">Copier</system:String>
    <system:String x:Key="BtnCopy.Tooltip">Copier les paramètres cochés depuis la sélection actuelle</system:String>
    <system:String x:Key="BtnPaste">Coller</system:String>
    <system:String x:Key="BtnPaste.Tooltip">Remplir les champs depuis le presse-papiers — cliquer Appliquer pour valider</system:String>
    <system:String x:Key="BtnFilter">Filtre</system:String>
    <system:String x:Key="BtnFilter.Tooltip">Créer/appliquer un filtre d'égalité de vue pour les paramètres cochés</system:String>
    <system:String x:Key="BtnApply">Appliquer</system:String>

    <!-- Option de conception — valeur par défaut -->
    <system:String x:Key="MainModel">Modèle principal</system:String>

    <!-- Messages de statut -->
    <system:String x:Key="Varies">Varie</system:String>
    <system:String x:Key="StatusNoSelection">Aucune sélection</system:String>
    <system:String x:Key="StatusOneElement">1 élément</system:String>
    <system:String x:Key="StatusElements">{} éléments</system:String>
    <system:String x:Key="StatusCopied">{} paramètre(s) copié(s)</system:String>

    <!-- Infobulles des paramètres -->
    <system:String x:Key="TooltipParamNotFound">Paramètre introuvable dans les éléments sélectionnés</system:String>
    <system:String x:Key="TooltipParamMissing">Paramètre non disponible pour tous les éléments sélectionnés</system:String>
    <system:String x:Key="TooltipParamReadOnly">Paramètre non modifiable pour tous les éléments sélectionnés</system:String>
    <system:String x:Key="TooltipParamOpaque">Paramètre d'option entière — affichage seul</system:String>
    <system:String x:Key="TooltipMixedValues">Valeurs mixtes dans la sélection</system:String>
    <system:String x:Key="TooltipUndo">Réinitialiser à la valeur de l'élément</system:String>

</ResourceDictionary>
