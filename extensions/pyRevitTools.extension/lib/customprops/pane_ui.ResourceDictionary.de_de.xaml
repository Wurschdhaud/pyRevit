<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Feste Parameterzeilen -->
    <system:String x:Key="LblWorkset">Workset</system:String>
    <system:String x:Key="ChkWorkset.Tooltip">Workset beim Kopieren einbeziehen</system:String>
    <system:String x:Key="ComboWorkset.Tooltip">Benutzer-Workset für dieses Element.</system:String>
    <system:String x:Key="LblDesignOption">Entwurfsoption</system:String>
    <system:String x:Key="ChkDesignOption.Tooltip">Entwurfsoption ist schreibgeschützt</system:String>
    <system:String x:Key="TbDesignOption.Tooltip">Schreibgeschützt. Die Entwurfsoptionszugehörigkeit kann nicht über die API geändert werden.</system:String>

    <!-- Parameterbereich -->
    <system:String x:Key="LblParameters">Parameter</system:String>

    <!-- Aktionsschaltflächen -->
    <system:String x:Key="BtnCopy">Kopieren</system:String>
    <system:String x:Key="BtnCopy.Tooltip">Markierte Parameter aus der aktuellen Auswahl kopieren</system:String>
    <system:String x:Key="BtnPaste">Einfügen</system:String>
    <system:String x:Key="BtnPaste.Tooltip">Felder aus der Zwischenablage füllen — mit „Anwenden" bestätigen</system:String>
    <system:String x:Key="BtnFilter">Filter</system:String>
    <system:String x:Key="BtnFilter.Tooltip">Gleichheitsfilter für markierte Parameter erstellen/anwenden</system:String>
    <system:String x:Key="BtnApply">Anwenden</system:String>

    <!-- Entwurfsoption Fallback -->
    <system:String x:Key="MainModel">Hauptmodell</system:String>

    <!-- Statusmeldungen -->
    <system:String x:Key="Varies">Variiert</system:String>
    <system:String x:Key="StatusNoSelection">Keine Auswahl</system:String>
    <system:String x:Key="StatusOneElement">1 Element</system:String>
    <system:String x:Key="StatusElements">{} Elemente</system:String>
    <system:String x:Key="StatusCopied">{} Parameter kopiert</system:String>

    <!-- Parameter-Tooltips -->
    <system:String x:Key="TooltipParamNotFound">Parameter nicht in ausgewählten Elementen gefunden</system:String>
    <system:String x:Key="TooltipParamMissing">Parameter nicht für alle ausgewählten Elemente verfügbar</system:String>
    <system:String x:Key="TooltipParamReadOnly">Parameter für alle ausgewählten Elemente schreibgeschützt</system:String>
    <system:String x:Key="TooltipParamOpaque">Ganzzahl-Optionsparameter — nur Anzeige</system:String>
    <system:String x:Key="TooltipMixedValues">Verschiedene Werte in der Auswahl</system:String>
    <system:String x:Key="TooltipUndo">Auf aktuellen Elementwert zurücksetzen</system:String>

</ResourceDictionary>
