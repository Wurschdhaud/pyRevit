<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Search bar -->
    <system:String x:Key="TooltipToggleRegex">정규식 / 부분 문자열 검색으로 전환합니다</system:String>

    <!-- Check / Uncheck / Toggle row -->
    <system:String x:Key="BtnCheckAll">모두 선택</system:String>
    <system:String x:Key="BtnUncheckAll">모두 해제</system:String>
    <system:String x:Key="BtnToggleAll">모두 전환</system:String>

    <!-- ListView column headers -->
    <system:String x:Key="ColParameter">매개변수</system:String>
    <system:String x:Key="ColValue">값</system:String>
    <system:String x:Key="ColCategory">카테고리</system:String>

    <!-- Category filter checkbox -->
    <system:String x:Key="ChkRestrictCategories">요소 카테고리로 선택 제한</system:String>
    <system:String x:Key="TooltipRestrictCategories">활성화 시 사각형 선택이 체크된 매개변수의 카테고리와 일치하는 요소만 선택합니다</system:String>

    <!-- Load-source buttons -->
    <system:String x:Key="BtnElemParams">요소 매개변수</system:String>
    <system:String x:Key="TooltipElemParams">요소를 선택하고 복사할 매개변수를 대화형으로 선택합니다</system:String>
    <system:String x:Key="BtnViewFilters">뷰 필터</system:String>
    <system:String x:Key="TooltipViewFilters">활성 뷰에서 모든 같음 필터 매개변수 값을 읽습니다</system:String>
    <system:String x:Key="BtnFilterElem">필터+요소</system:String>
    <system:String x:Key="TooltipFilterElem">선택한 요소에서 가장 일반적인 필터 매개변수 값을 읽습니다</system:String>

    <!-- Paste buttons -->
    <system:String x:Key="BtnPasteOne">하나 붙여넣기</system:String>
    <system:String x:Key="TooltipPasteOne">요소를 반복해서 선택하고 체크된 매개변수를 붙여넣습니다</system:String>
    <system:String x:Key="BtnPasteBox">박스 붙여넣기</system:String>
    <system:String x:Key="TooltipPasteBox">사각형을 반복해서 그려 포함된 요소에 체크된 매개변수를 붙여넣습니다</system:String>
    <system:String x:Key="BtnPasteSel">선택에 붙여넣기</system:String>
    <system:String x:Key="TooltipPasteSel">현재 Revit 선택 항목에 체크된 매개변수를 붙여넣습니다 (1회 실행)</system:String>

</ResourceDictionary>
